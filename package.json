{
  "name": "horus-eye",
  "version": "1.0.0",
  "private": true,
  "description": "Horus Eye — 3D Dünya Küresi Görselleştirme",
  "scripts": {
    "dev:full": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "dev:frontend": "cd frontend && npm run dev",
    "install:frontend": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
