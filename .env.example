# ─── Horus Eye — Ortam Değişkenleri ────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env asla git'e commit'lenmez.

# Veritabanı (PostgreSQL)
DB_NAME=horus_eye
DB_USER=postgres
DB_PASSWORD=guclu-bir-sifre-yazin
DATABASE_URL=jdbc:postgresql://localhost:5432/horus_eye

# Backend
SERVER_PORT=8080
ALLOWED_ORIGIN=http://localhost:4200

# Redis (opsiyonel — boş bırakılırsa cache devre dışı, backend yine çalışır)
REDIS_HOST=localhost
REDIS_PORT=6379
FEED_CACHE_TTL=60

# Frontend
API_URL=http://localhost:8080
